{
  "_comment": "LEGACY flat format (tests + old installs). For new deployments use master.config.example.json → master.config.json — one file + credentials.json; set CONFIG_PATH to master.config.json. See server/lib/master-config.js.",
  "gen": {
    "scriptPath": "/opt/kafka-usermgmt/gen.sh",
    "baseDir": "/opt/kafka-usermgmt",
    "downloadDir": "/opt/kafka-usermgmt/user_output",
    "kafkaBin": "/opt/kafka-usermgmt/kafka_2.13-3.6.1/bin",
    "bootstrapServers": "host1:443,host2:443",
    "ocPath": "/host/usr/bin",
    "clientConfig": "/opt/kafka-usermgmt/configs/kafka-client.properties",
    "adminConfig": "/opt/kafka-usermgmt/configs/kafka-client-master.properties",
    "logFile": "/opt/kafka-usermgmt/provisioning.log",
    "k8sSecretName": "kafka-server-side-credentials",
    "kubeconfigPath": "/opt/kafka-usermgmt/.kube/config",
    "sites": [
      { "name": "region-a", "namespace": "kafka-namespace-a", "ocContext": "ocp-region-a" },
      { "name": "region-b", "namespace": "kafka-namespace-b", "ocContext": "ocp-region-b" }
    ],
    "namespace": "kafka-namespace-a",
    "ocContext": "ocp-region-a"
  },
  "server": {
    "port": 3443,
    "environments": {
      "enabled": true,
      "file": "environments.json"
    },
    "auth": {
      "enabled": false,
      "secretsFile": "auth-secrets.json"
    },
    "https": {
      "enabled": false,
      "keyPath": "/app/ssl/server.key",
      "certPath": "/app/ssl/server.crt"
    }
  }
}
