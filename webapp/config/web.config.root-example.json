{
  "_comment": "Single source of truth ใต้ /opt/kafka-usermgmt. path ใน config = path ที่ container เห็น (mount -v ROOT:ROOT; .kube อยู่ใต้ ROOT หรือ mount เป็น ROOT/.kube-external). ocPath /host/usr/bin = host oc.",
  "gen": {
    "rootDir": "/opt/kafka-usermgmt",
    "ocPath": "/host/usr/bin",
    "logFile": "/tmp/provisioning.log",
    "k8sSecretName": "kafka-server-side-credentials",
    "bootstrapServers": "kafka-bootstrap-a.example.com:443,kafka-bootstrap-b.example.com:443",
    "kubeconfigPath": "/opt/kafka-usermgmt/.kube/config",
    "sites": [
      { "name": "region-a", "namespace": "kafka-namespace-a", "ocContext": "ocp-region-a" },
      { "name": "region-b", "namespace": "kafka-namespace-b", "ocContext": "ocp-region-b" }
    ],
    "namespace": "kafka-namespace-a",
    "ocContext": "ocp-region-a"
  },
  "server": {
    "port": 3443,
    "https": {
      "enabled": true,
      "keyPath": "/app/ssl/server.key",
      "certPath": "/app/ssl/server.crt"
    }
  }
}
